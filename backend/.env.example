// backend/.env.example
# DeepSeek API Configuration
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# TFTP Directory (where embedded boards upload logs)
TFTP_RECEIVE_DIR=./tftp_receive

# WebSocket Server Port
WS_PORT=8765

# HTTP Server Port
HTTP_PORT=8000

# Directory for generated .patch files
PATCHES_DIR=./patches

# Logging Level
LOG_LEVEL=INFO
