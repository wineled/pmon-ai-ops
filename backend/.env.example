# ── DeepSeek API ─────────────────────────────────
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# ── Directories ──────────────────────────────────
# TFTP log directory (where embedded boards upload logs)
TFTP_RECEIVE_DIR=./tftp_receive
# Code index directories for LLM retrieval (comma-separated, relative to backend/)
CODE_INDEX_DIRS=../,../../
# Patch output directory
PATCHES_DIR=./patches

# ── Server ───────────────────────────────────────
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# ── Logging ──────────────────────────────────────
LOG_LEVEL=INFO
