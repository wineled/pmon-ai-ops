# PMON-AI-OPS Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════════════════
# AI Configuration (Required)
# ═══════════════════════════════════════════════════════════════════════════

# DeepSeek API Key - Get from https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek API Base URL (optional, defaults to official endpoint)
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Model to use (optional, defaults to deepseek-chat)
DEEPSEEK_MODEL=deepseek-chat

# ═══════════════════════════════════════════════════════════════════════════
# Backend Configuration
# ═══════════════════════════════════════════════════════════════════════════

# HTTP Server Port
HTTP_PORT=8000

# Log Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# TFTP Receive Directory (where log files are uploaded)
TFTP_RECEIVE_DIR=./tftp_receive

# Code Index Directories (comma-separated paths for LLM context)
CODE_INDEX_DIRS=../,../../

# ═══════════════════════════════════════════════════════════════════════════
# Frontend Configuration
# ═══════════════════════════════════════════════════════════════════════════

# Vite Dev Server Port
VITE_PORT=5173

# Backend API URL (for production build)
VITE_API_URL=http://localhost:8000

# WebSocket URL (for production build)
VITE_WS_URL=ws://localhost:8000/ws

# ═══════════════════════════════════════════════════════════════════════════
# External Access (花生壳配置)
# ═══════════════════════════════════════════════════════════════════════════

# External domain for花生壳
EXTERNAL_DOMAIN=https://22mj4798in35.vicp.fun

# Proxy port for花生壳
PROXY_PORT=10444

# ═══════════════════════════════════════════════════════════════════════════
# Security (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# CORS Origins (comma-separated, defaults to localhost)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# API Rate Limit (requests per minute)
RATE_LIMIT=60

# ═══════════════════════════════════════════════════════════════════════════
# Development (Optional)
# ═══════════════════════════════════════════════════════════════════════════

# Enable auto-reload
RELOAD=true

# Debug mode
DEBUG=false

# Test mode (uses mock data)
TEST_MODE=false
